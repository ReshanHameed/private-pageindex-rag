# Local Ollama server. This project must only call a local Ollama endpoint.
OLLAMA_BASE_URL=http://localhost:11434

# Default local model requested for this project.
OLLAMA_MODEL=gemma4:e4b

# Local storage directory for SQLite, uploaded PDFs, extracted pages, and trees.
DATA_DIR=data

# Prompt budget controls for local tree search and answer generation.
MAX_TREE_PROMPT_CHARS=45000
MAX_PAGE_CHARS=12000
TREE_MAX_PAGES_PER_NODE=10
